# Apple Developer credentials for signing and notarizing macOS builds.
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# Your Apple ID email
APPLE_ID=you@example.com

# An app-specific password from appleid.apple.com
# (NOT your Apple ID login password)
APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your 10-character Apple Developer Team ID
# Found at developer.apple.com/account (top-right membership section)
APPLE_TEAM_ID=XXXXXXXXXX
